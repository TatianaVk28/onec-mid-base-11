
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// ++ Доработка ДЗ Добавление группы "Скидка", реквизита "СогласованнаяСкидка" и кнопки "ПересчитатьСоСкидкой"
	
	Группа = Элементы.Добавить("ГруппаШапка", Тип("ГруппаФормы"), ЭтаФорма.Элементы.ГруппаШапкаЛево);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок = "Скидка:";
	
	ТипРеквизита = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(5, 2));
	
	ДобавляемыеРеквизиты = Новый Массив;
	РеквизитФормы = Новый РеквизитФормы("РеквизитСогласованнаяСкидка", ТипРеквизита, "", "СогласованнаяСкидка");
	ДобавляемыеРеквизиты.Добавить(РеквизитФормы);
	
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	ПолеВвода = Элементы.Добавить("ЭлементСогласованнаяСкидка", Тип("ПолеФормы"), Группа);
	ПолеВвода.Вид = ВидПоляФормы.ПолеВвода;
	ПолеВвода.ПутьКДанным = "Объект.ДЗ_СогласованнаяСкидка";
	ПолеВвода.УстановитьДействие("ПриИзменении", "ПриИзмененииСогласованнойСкидки"); 
	
	Команда = Команды.Добавить("ПересчитатьСоСкидкой1");
	Команда.Заголовок = "КомандаПересчитатьТаблицуСУчетомСкидки";
	Команда.Действие = "КомандаПересчитатьСоСкидкой";
	
	КнопкаФормы = Элементы.Добавить("КнопкаПересчитатьСоСкидкой", Тип("КнопкаФормы"), Группа);
	КнопкаФормы.ИмяКоманды = "ПересчитатьСоСкидкой"; 
	КнопкаФормы.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	
	// -- Доработка ДЗ Добавление группы "Скидка", реквизита "СогласованнаяСкидка" и кнопки "ПересчитатьСоСкидкой" 
		
КонецПроцедуры

