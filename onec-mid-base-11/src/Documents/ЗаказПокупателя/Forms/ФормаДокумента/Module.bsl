#Область СлужебныеПроцедурыИФункции

&НаКлиенте

Асинх Процедура ПриИзмененииСогласованнойСкидки(Элемент, СтрокаТабЧ)
	//++ Дорабатка Пересчитать сумму с учетом скидки
	Если ЗначениеЗаполнено(Объект.Товары)= Ложь и ЗначениеЗаполнено(Объект.Услуги) = Ложь Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Ответ = Ждать ВопросАсинх("Пересчитать сумму с учетом скидки?", РежимДиалогаВопрос.ДаНет); 
	
	Если Ответ = КодВозвратаДиалога.Да Тогда 
		ПересчитатьТаблицуТовары();
		ПересчитатьТаблицуУслуги();	
	КонецЕсли;
	
	РассчитатьСуммуДокумента(); 
	//--
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьТаблицуТовары() 
	//++ Дорабатка Пересчитать сумму с учетом скидки	
	Для Каждого СтрокаТЧ Из Объект.Товары Цикл 	
		РассчитатьСуммуСтроки(СтрокаТЧ);			
	КонецЦикла;
	//--
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьТаблицуУслуги() 
		
	Для Каждого СтрокаТЧ Из Объект.Услуги Цикл 	
		РассчитатьСуммуСтроки(СтрокаТЧ);			
	КонецЦикла;
	
КонецПроцедуры
	
//--

&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	КоэффициентСкидки = 1 - ТекущиеДанные.Скидка / 100;
	// ++ Доработка ДЗ Добавление группы "Скидка", реквизита "СогласованнаяСкидка" и кнопки "ПересчитатьСоСкидкой"
	//ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество * КоэффициентСкидки;
	Если ЗначениеЗаполнено(КоэффициентСкидки) Тогда
		КоэффициентСкидкиДокумента = 1 - КоэффициентСкидки + Объект.ДЗ_СогласованнаяСкидка/100;
	Иначе 
		КоэффициентСкидкиДокумента = Объект.ДЗ_СогласованнаяСкидка/100;
	КонецЕсли;
	
	Если КоэффициентСкидкиДокумента <= 1 Тогда
		ТекущиеДанные.Сумма = (ТекущиеДанные.Цена - ТекущиеДанные.Цена * КоэффициентСкидкиДокумента) * ТекущиеДанные.Количество;
	Иначе
		ТекущиеДанные.Сумма = 0;
		Сообщение = СтрШаблон("По товару/услуге %1 скидка превышает 100 процентов", ТекущиеДанные.Номенклатура);
		Сообщить(Сообщение);
	КонецЕсли;	
    // -- Доработка ДЗ Добавление группы "Скидка", реквизита "СогласованнаяСкидка" и кнопки "ПересчитатьСоСкидкой"
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

